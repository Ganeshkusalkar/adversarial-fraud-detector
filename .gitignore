# Virtual environment
venv/
.venv/
env/
ENV/

# Python caching
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# Dataset files (avoid pushing gigabytes of Kaggle data to GitHub)
data/*
!data/.gitkeep
*.csv
*.xlsx

# Local environment configs and secrets
.env
config/*_config.yaml
!config/base_config.yaml

# IDE settings
.vscode/
.idea/

# Large model artifacts (checkpoints)
artifacts/
*.pt
*.pth
*.onnx
*.pkl

# Local temporary or unnecessary files
*.zip
*.docx
extracted_doc.txt
adversarial-fraud-detector/
